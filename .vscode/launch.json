{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Jamtama (Chrome)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/jamtama",
      "program": "lib/main.dart",
      "args": ["-d", "chrome", "--web-port", "8080"]
    },
    {
      "name": "Jamtama (Windows)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/jamtama",
      "program": "lib/main.dart",
      "args": ["-d", "windows"]
    }
  ]
}
